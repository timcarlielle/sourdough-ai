{
  "name": "sourdough-ai",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:web & npm run dev:ingest & npm run dev:worker",
    "dev:web": "npm run dev --workspace=web-app",
    "dev:ingest": "npm run dev --workspace=ingest-api",
    "dev:worker": "npm run dev --workspace=worker",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=packages/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema=packages/db/prisma/schema.prisma",
    "db:seed": "npm run seed --workspace=db",
    "db:studio": "prisma studio --schema=packages/db/prisma/schema.prisma"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "vitest": "^2.1.9"
  },
  "license": "MIT"
}
