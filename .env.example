# ============================================================================
# Sourdough AI — environment configuration
# Copy to .env and adjust. With the default docker-compose.yml you only NEED
# to set NEXTAUTH_SECRET; everything else has sensible defaults.
# ============================================================================

# --- Required -----------------------------------------------------------------

# Session/JWT signing secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# --- Database & queue (docker compose sets these per-service automatically) ----

# Used when running apps directly on the host (npm run dev:*).
# Compose maps Postgres to host port 5433 in the dev stack.
DATABASE_URL=postgresql://sourdough:sourdough@localhost:5433/sourdough
REDIS_URL=redis://localhost:6379

# Postgres credentials for the compose stacks (defaults shown).
# CHANGE THE PASSWORD if Postgres is exposed on your network (split stack).
POSTGRES_USER=sourdough
POSTGRES_PASSWORD=sourdough
POSTGRES_DB=sourdough

# --- Web app --------------------------------------------------------------------

# The externally reachable URL of the web app (used for auth callbacks and
# voice-file URLs). Set to your server's address, e.g. https://sourdough.example.com
NEXTAUTH_URL=http://localhost:3000

# Default display timezone (IANA name). Users can override per-account.
APP_TIMEZONE=UTC
# Same value, exposed to the browser for client-rendered dates.
NEXT_PUBLIC_APP_TIMEZONE=UTC

# Host ports for the compose stacks.
WEB_PORT_HOST=3000
INGEST_PORT_HOST=3001
# INGEST_API_PORT=3001            # port the ingest service listens on (non-Docker)

# --- AI features (OPTIONAL) -----------------------------------------------------

# Enables voice logging (transcription + parsing), dashboard insights, and
# recipe scraping. Leave unset to run without AI — everything else works.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_TRANSCRIBE=gpt-4o-mini-transcribe
# OPENAI_MODEL_PARSE=gpt-4o-mini

# --- Uploads (voice clips) -------------------------------------------------------

# Local path for uploaded audio. In Docker this is a shared volume (/app/uploads)
# mounted into both web-app and worker.
UPLOAD_DIR=./uploads

# --- Split-stack / advanced ------------------------------------------------------

# When the worker cannot share UPLOAD_DIR with the web app (separate hosts),
# it fetches audio over HTTP. Set the same random secret in both services to
# authorize those internal fetches: openssl rand -hex 32
# INTERNAL_API_SECRET=

# URL the worker uses to reach the web app from inside the compose network.
# INTERNAL_WEB_URL=http://web-app:3000

# Enable the starter-prediction debug UI on /analytics.
# NEXT_PUBLIC_STARTER_DEBUG=1
